{application,zig_parser,
             [{modules,['Elixir.Mix.Tasks.ParseZig','Elixir.Zig.Parser',
                        'Elixir.Zig.Parser.Array','Elixir.Zig.Parser.Asm',
                        'Elixir.Zig.Parser.AssignExpr',
                        'Elixir.Zig.Parser.Block',
                        'Elixir.Zig.Parser.Collected',
                        'Elixir.Zig.Parser.ComptimeDecl',
                        'Elixir.Zig.Parser.Const',
                        'Elixir.Zig.Parser.ContainerDecl',
                        'Elixir.Zig.Parser.ContainerDeclaration',
                        'Elixir.Zig.Parser.Decl','Elixir.Zig.Parser.Enum',
                        'Elixir.Zig.Parser.ErrorSet',
                        'Elixir.Zig.Parser.ErrorUnionExpr',
                        'Elixir.Zig.Parser.Expr','Elixir.Zig.Parser.For',
                        'Elixir.Zig.Parser.Function',
                        'Elixir.Zig.Parser.GlobalVarDecl',
                        'Elixir.Zig.Parser.If','Elixir.Zig.Parser.InitList',
                        'Elixir.Zig.Parser.ParamDecl',
                        'Elixir.Zig.Parser.ParseError',
                        'Elixir.Zig.Parser.Pointer',
                        'Elixir.Zig.Parser.PrimaryExpr',
                        'Elixir.Zig.Parser.PrimaryTypeExpr',
                        'Elixir.Zig.Parser.Statement',
                        'Elixir.Zig.Parser.Struct',
                        'Elixir.Zig.Parser.Struct.Field',
                        'Elixir.Zig.Parser.StructLiteral',
                        'Elixir.Zig.Parser.Switch','Elixir.Zig.Parser.Test',
                        'Elixir.Zig.Parser.TypeExpr',
                        'Elixir.Zig.Parser.Union','Elixir.Zig.Parser.Var',
                        'Elixir.Zig.Parser.VarDeclExprStatement',
                        'Elixir.Zig.Parser.VarDeclProto',
                        'Elixir.Zig.Parser.While']},
              {optional_applications,[]},
              {applications,[kernel,stdlib,elixir,logger,ssl,inets]},
              {description,"a zig parser in elixir"},
              {registered,[]},
              {vsn,"0.6.0"}]}.
